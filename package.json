{
  "name": "odds-value-analyzer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "test": "vitest run",
    "test:ui": "npm.cmd run build && playwright test",
    "test:ui:only": "playwright test",
    "monitor:odds": "node scripts/odds-monitor.mjs",
    "monitor:odds:once": "node scripts/odds-monitor.mjs --once",
    "import:hkjc": "node scripts/hkjc-import.mjs",
    "logos:build": "node scripts/build-team-logos.mjs",
    "check:data": "node scripts/check-data-integrity.mjs",
    "db:migrate": "node server/db/migrate-cli.mjs",
    "db:import:legacy": "node scripts/import-legacy-to-postgres.mjs",
    "db:check:parity": "node scripts/check-postgres-parity.mjs",
    "auth:create-owner": "node scripts/create-owner.mjs",
    "auth:benchmark": "node scripts/benchmark-password.mjs",
    "server": "node server/entry.mjs",
    "server:self-test": "node server/entry.mjs --self-test",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@node-rs/argon2": "2.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "pg": "8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
